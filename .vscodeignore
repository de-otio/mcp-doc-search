# Internal/dev files and local config — never ship in the VSIX.
CLAUDE.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
.mcp.json
.doc-search-index/**
.vscode/**
*.vsix
package-lock.json

# Source maps (large, only needed for debugging)
dist/**/*.map
node_modules/**/*.map

# onnxruntime-web is unused (we use onnxruntime-node for inference)
node_modules/onnxruntime-web/**

# node_modules dev cruft: docs, dotfiles, tests, examples, original sources.
# We only need the compiled .js/.cjs/.d.ts files at runtime.
node_modules/**/CHANGELOG*
node_modules/**/changelog*
node_modules/**/HISTORY*
node_modules/**/history*
node_modules/**/CONTRIBUTING*
node_modules/**/contributing*
node_modules/**/AUTHORS*
node_modules/**/CODEOWNERS
node_modules/**/.eslintrc*
node_modules/**/.npmignore
node_modules/**/.travis.yml
node_modules/**/.editorconfig
node_modules/**/.babelrc*
node_modules/**/.prettierrc*
node_modules/**/.nvmrc
node_modules/**/.npmrc
node_modules/**/.github/**
node_modules/**/.vscode/**
node_modules/**/.idea/**
node_modules/**/test/**
node_modules/**/tests/**
node_modules/**/__tests__/**
node_modules/**/spec/**
node_modules/**/example/**
node_modules/**/examples/**
node_modules/**/docs/**
node_modules/**/doc/**
node_modules/**/src/**
node_modules/**/*.ts
node_modules/**/*.d.ts.map

# sharp + libvips: transitive dep of transformers. We don't use image
# embedding, but transformers' webpack-bundled CJS eagerly require()s
# sharp at module load — so stripping it crashes LocalEmbedder before it
# even reaches the (text-only) pipeline. Ship it; ~16MB on darwin-arm64,
# zero impact for users on Ollama/OpenAI.

# HuggingFace transformers: ship only the node CJS entry + package.json.
# embedder.ts uses require() (not dynamic import()), so the .mjs siblings
# can stay stripped (saves ~3.5MB).
node_modules/@huggingface/transformers/src/**
node_modules/@huggingface/transformers/types/**
node_modules/@huggingface/transformers/.cache/**
node_modules/@huggingface/transformers/dist/ort-wasm-*
node_modules/@huggingface/transformers/dist/transformers.js
node_modules/@huggingface/transformers/dist/transformers.js.map
node_modules/@huggingface/transformers/dist/transformers.min.js
node_modules/@huggingface/transformers/dist/transformers.min.js.map
node_modules/@huggingface/transformers/dist/transformers.web.*
node_modules/@huggingface/transformers/dist/transformers.node.mjs
node_modules/@huggingface/transformers/dist/transformers.node.mjs.map
node_modules/@huggingface/transformers/dist/transformers.node.min.mjs
node_modules/@huggingface/transformers/dist/transformers.node.min.mjs.map
node_modules/@huggingface/transformers/dist/transformers.node.min.cjs
node_modules/@huggingface/transformers/dist/transformers.node.min.cjs.map

# onnxruntime-node: prune script handles cross-platform binaries,
# but also exclude source/script dirs not needed at runtime
node_modules/onnxruntime-node/lib/**
node_modules/onnxruntime-node/script/**
